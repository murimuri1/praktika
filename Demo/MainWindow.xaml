<Window x:Class="Demo.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:Demo"
        mc:Ignorable="d"
        Icon="/Sourse/Icon.ico"
        Title="Game Store" Height="720" Width="1280"
        WindowStartupLocation="CenterScreen"
        ResizeMode="CanResize"
        WindowState="Maximized"
        MinWidth="800" 
        MinHeight="450"
        Background="#1b2838">

    <Grid>
        <Grid.RowDefinitions>
            <!-- Высота Auto позволяет шапке полностью скрываться на странице авторизации -->
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- Основная панель шапки (HeaderPanel) -->
        <StackPanel x:Name="HeaderPanel" Grid.Row="0">

            <!-- 1. Тонкая верхняя полоса (Steam, Вид, Друзья...) -->
            <StackPanel Orientation="Horizontal" Background="#171a21" Height="30">
                
            </StackPanel>

            <!-- 2. Главное меню навигации -->
            <Grid Background="#171a21" Height="60">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <!-- Назад -->
                    <ColumnDefinition Width="*"/>
                    <!-- Разделы -->
                    <ColumnDefinition Width="Auto"/>
                    <!-- Профиль -->
                </Grid.ColumnDefinitions>

                <!-- Кнопка Назад (Стрелка) -->
                <Button x:Name="BtnBack" 
                        Grid.Column="0" 
                        Click="BtnBack_Click" 
                        Margin="15,0,20,0" 
                        Cursor="Hand">
                    <Button.Template>
                        <ControlTemplate TargetType="Button">
                            <Border Background="Transparent" Padding="10">
                                <TextBlock Text="🡄" FontSize="26" FontWeight="Bold">
                                    <TextBlock.Style>
                                        <Style TargetType="TextBlock">
                                            <Setter Property="Foreground" Value="#5c6d7e"/>
                                            <Style.Triggers>
                                                <Trigger Property="IsMouseOver" Value="True">
                                                    <Setter Property="Foreground" Value="White"/>
                                                </Trigger>
                                            </Style.Triggers>
                                        </Style>
                                    </TextBlock.Style>
                                </TextBlock>
                            </Border>
                        </ControlTemplate>
                    </Button.Template>
                </Button>

                <!-- Список разделов -->
                <StackPanel Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Center">
                    <TextBlock Text="МАГАЗИН" Foreground="#c5c3c0" FontSize="18" FontWeight="SemiBold" Margin="0,0,30,0" VerticalAlignment="Center"/>

                    <!-- Активный раздел (Библиотека) с синей линией -->
                    <StackPanel VerticalAlignment="Center" Margin="0,0,30,0">
                        <TextBlock Text="БИБЛИОТЕКА" Foreground="#1a9fff" FontSize="18" FontWeight="SemiBold" Margin="0,0,0,5"/>
                        <Border Height="3" Background="#1a9fff" HorizontalAlignment="Stretch"/>
                    </StackPanel>

                    
                </StackPanel>

                <!-- Блок текущего пользователя -->
                <StackPanel Grid.Column="2" Orientation="Horizontal" VerticalAlignment="Center" Margin="0,0,20,0">

                    <!-- Динамическое имя (админ или юзер) -->
                    <TextBlock x:Name="TxtUserName" 
                               Text="" 
                               Foreground="White" 
                               FontSize="14" 
                               VerticalAlignment="Center"
                               Margin="0,0,15,0"/>

                    <!-- Квадратная аватарка -->
                    <Border Width="36" Height="36" CornerRadius="4" Background="#3d4450" BorderBrush="#2a475e" BorderThickness="2">
                        <TextBlock Text="👤" Foreground="#c5c3c0" HorizontalAlignment="Center" VerticalAlignment="Center" FontSize="20"/>
                    </Border>

                </StackPanel>
            </Grid>
        </StackPanel>

        <!-- Контент приложения (сюда грузятся страницы) -->
        <Frame x:Name="FrameMain" 
               Grid.Row="1" 
               NavigationUIVisibility="Hidden"/>

    </Grid>
</Window>