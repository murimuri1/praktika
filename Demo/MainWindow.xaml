<Window x:Class="Demo.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Game Store" Height="720" Width="1280"
        WindowStartupLocation="CenterScreen"
        WindowState="Maximized"
        MinWidth="800" MinHeight="500"
        Background="#1b2838"
        FontFamily="Segoe UI"
        Icon="/Sourse/app_icon.png">

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <!-- Шапка -->
            <RowDefinition Height="*"/>
            <!-- Контент -->
        </Grid.RowDefinitions>

        <!-- ПАНЕЛЬ НАВИГАЦИИ -->
        <StackPanel x:Name="HeaderPanel" Grid.Row="0">
            <Grid Background="#171a21" Height="70">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <!-- Назад -->
                    <ColumnDefinition Width="*"/>
                    <!-- Меню -->
                    <ColumnDefinition Width="Auto"/>
                    <!-- Профиль -->
                </Grid.ColumnDefinitions>

                <!-- КНОПКА НАЗАД -->
                <Button x:Name="BtnBack" Grid.Column="0" Click="BtnBack_Click" Margin="15,0,15,0" Cursor="Hand">
                    <Button.Template>
                        <ControlTemplate TargetType="Button">
                            <Border Background="Transparent" VerticalAlignment="Center">
                                <TextBlock Text="🡄" FontSize="32" FontWeight="Bold">
                                    <TextBlock.Style>
                                        <Style TargetType="TextBlock">
                                            <Setter Property="Foreground" Value="#5c6d7e"/>
                                            <Style.Triggers>
                                                <Trigger Property="IsMouseOver" Value="True">
                                                    <Setter Property="Foreground" Value="#1a9fff"/>
                                                </Trigger>
                                            </Style.Triggers>
                                        </Style>
                                    </TextBlock.Style>
                                </TextBlock>
                            </Border>
                        </ControlTemplate>
                    </Button.Template>
                </Button>

                <!-- МЕНЮ: МАГАЗИН, БИБЛИОТЕКА, ДОБАВИТЬ/ПРАВКА -->
                <StackPanel Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Center" Margin="10,0,0,0">

                    <!-- Магазин -->
                    <Button Click="BtnStore_Click" Margin="0,0,40,0">
                        <Button.Template>
                            <ControlTemplate TargetType="Button">
                                <StackPanel VerticalAlignment="Center" Cursor="Hand" Background="Transparent">
                                    <TextBlock x:Name="txt" Text="МАГАЗИН" FontSize="22" FontWeight="SemiBold" Foreground="#c5c3c0"/>
                                    <Border x:Name="ind" Height="3" Background="#1a9fff" Margin="0,5,0,0" Visibility="Collapsed"/>
                                </StackPanel>
                                <ControlTemplate.Triggers>
                                    <DataTrigger Binding="{Binding RelativeSource={RelativeSource AncestorType=Window}, Path=Title}" Value="МАГАЗИН">
                                        <Setter TargetName="txt" Property="Foreground" Value="White"/>
                                        <Setter TargetName="ind" Property="Visibility" Value="Visible"/>
                                    </DataTrigger>
                                </ControlTemplate.Triggers>
                            </ControlTemplate>
                        </Button.Template>
                    </Button>

                    <!-- Библиотека -->
                    <Button Click="BtnLibrary_Click" Margin="0,0,40,0">
                        <Button.Template>
                            <ControlTemplate TargetType="Button">
                                <StackPanel VerticalAlignment="Center" Cursor="Hand" Background="Transparent">
                                    <TextBlock x:Name="txt" Text="БИБЛИОТЕКА" FontSize="22" FontWeight="SemiBold" Foreground="#c5c3c0"/>
                                    <Border x:Name="ind" Height="3" Background="#1a9fff" Margin="0,5,0,0" Visibility="Collapsed"/>
                                </StackPanel>
                                <ControlTemplate.Triggers>
                                    <DataTrigger Binding="{Binding RelativeSource={RelativeSource AncestorType=Window}, Path=Title}" Value="БИБЛИОТЕКА">
                                        <Setter TargetName="txt" Property="Foreground" Value="White"/>
                                        <Setter TargetName="ind" Property="Visibility" Value="Visible"/>
                                    </DataTrigger>
                                </ControlTemplate.Triggers>
                            </ControlTemplate>
                        </Button.Template>
                    </Button>

                    <!-- Динамическая кнопка ДОБАВИТЬ/ПРАВКА -->
                    <Button x:Name="BtnAddGame" Click="BtnAddGame_Click" Visibility="Collapsed">
                        <Button.Template>
                            <ControlTemplate TargetType="Button">
                                <StackPanel VerticalAlignment="Center" Cursor="Hand" Background="Transparent">
                                    <TextBlock x:Name="txt" Text="ДОБАВИТЬ" FontSize="22" FontWeight="SemiBold" Foreground="#c5c3c0"/>
                                    <Border x:Name="ind" Height="3" Background="#1a9fff" Margin="0,5,0,0" Visibility="Collapsed"/>
                                </StackPanel>
                                <ControlTemplate.Triggers>
                                    <!-- Триггер для ДОБАВЛЕНИЯ -->
                                    <DataTrigger Binding="{Binding RelativeSource={RelativeSource AncestorType=Window}, Path=Title}" Value="ДОБАВЛЕНИЕ ИГРЫ">
                                        <Setter TargetName="txt" Property="Foreground" Value="White"/>
                                        <Setter TargetName="ind" Property="Visibility" Value="Visible"/>
                                        <Setter TargetName="txt" Property="Text" Value="ДОБАВИТЬ"/>
                                    </DataTrigger>
                                    <!-- Триггер для ПРАВКИ -->
                                    <DataTrigger Binding="{Binding RelativeSource={RelativeSource AncestorType=Window}, Path=Title}" Value="РЕДАКТИРОВАНИЕ ИГРЫ">
                                        <Setter TargetName="txt" Property="Foreground" Value="White"/>
                                        <Setter TargetName="ind" Property="Visibility" Value="Visible"/>
                                        <Setter TargetName="txt" Property="Text" Value="ПРАВКА"/>
                                    </DataTrigger>
                                </ControlTemplate.Triggers>
                            </ControlTemplate>
                        </Button.Template>
                    </Button>
                </StackPanel>

                <!-- ПРОФИЛЬ -->
                <StackPanel Grid.Column="2" Orientation="Horizontal" VerticalAlignment="Center" Margin="0,0,25,0">
                    <TextBlock x:Name="TxtUserName" Text="user" Foreground="White" FontSize="16" VerticalAlignment="Center" Margin="0,0,15,0"/>
                    <Border Width="42" Height="42" CornerRadius="4" Background="#3d4450" BorderBrush="#2a475e" BorderThickness="2">
                        <TextBlock Text="👤" Foreground="#c5c3c0" HorizontalAlignment="Center" VerticalAlignment="Center" FontSize="24"/>
                    </Border>
                </StackPanel>
            </Grid>
            <Border Height="1" Background="#1a9fff" Opacity="0.3"/>
        </StackPanel>

        <!-- КОНТЕНТ -->
        <Frame x:Name="FrameMain" Grid.Row="1" NavigationUIVisibility="Hidden"/>
    </Grid>
</Window>