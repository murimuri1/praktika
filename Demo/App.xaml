<Application x:Class="Demo.App"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:local="clr-namespace:Demo"
             StartupUri="MainWindow.xaml">
    
    
    <Application.Resources>
  <!-- Чтобы применить стиль ко всем кнопкам в ИС -->
        <Style TargetType="{x:Type Button}">
            <Setter Property="FontFamily" Value="Times New Roman"/>
            <!-- Шрифт -->
            <Setter Property="FontSize" Value="18"/>
            <!-- Размер шрифта -->
            <Setter Property="Background" Value="#00FA9A"/>
            <!-- Фон кнопки -->
            <Setter Property="Margin" Value="5"/>
            <!-- Oтступы -->
            <Setter Property="MinWidth" Value="100"/>
            <!-- Минимальная ширина -->
        </Style>
        <!-- Чтобы применить стиль ко всему тексту в ИС -->
        <Style TargetType="{x:Type TextBlock}">
            <Setter Property="FontFamily" Value="Times New Roman"/>
            <Setter Property="FontSize" Value="18"/>
            <!-- Размер шрифта -->
            <Setter Property="Margin" Value="5"/>
            <!-- Oтступы -->
        </Style>
        <!-- Чтобы применить стиль к текстовым полям ИС -->
        <Style TargetType="{x:Type TextBox}">
            <Setter Property="FontFamily" Value="Times New Roman"/>
            <Setter Property="FontSize" Value="18"/>
            <!-- Размер шрифта -->
            <Setter Property="Margin" Value="5"/>
            <!-- Oтступы -->
            <Setter Property="Height" Value="40"/>
            <Setter Property="Width" Value="180"/>
        </Style>
        <!-- Чтобы применить стиль к выпадающим спискам ИС -->
        <Style TargetType="{x:Type ComboBox}">
            <Setter Property="FontFamily" Value="Times New Roman"/>
            <Setter Property="FontSize" Value="18"/>
            <!-- Размер шрифта -->
            <Setter Property="Margin" Value="5"/>
            <!-- Oтступы -->
            <Setter Property="Height" Value="40"/>
            <Setter Property="Width" Value="180"/>
        </Style>
        <Style TargetType="{x:Type DatePicker}">
            <Setter Property="FontFamily" Value="Times New Roman"/>
            <Setter Property="FontSize" Value="18"/>
            <!-- Размер шрифта -->
            <Setter Property="Margin" Value="5"/>
            <!-- Oтступы -->
            <Setter Property="Height" Value="40"/>
            <Setter Property="Width" Value="180"/>
        </Style>
    </Application.Resources>
</Application>
