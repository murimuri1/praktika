<Page x:Class="Demo.Pages.GamePage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:local="clr-namespace:Demo.Pages"
      Loaded="Page_Loaded"
      Title="МАГАЗИН"
      FontFamily="Segoe UI">

    <Page.Resources>
        <local:RatingToStarsConverter x:Key="RatingToStarsConverter"/>
        <local:RatingToColorConverter x:Key="RatingToColorConverter"/>

        <!-- СТИЛЬ ДЛЯ ПУНКТОВ ВЫПАДАЮЩЕГО СПИСКА -->
        <Style TargetType="ComboBoxItem">
            <Setter Property="Background" Value="#1b2838"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="Padding" Value="10,8"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ComboBoxItem">
                        <Border x:Name="gd" Background="{TemplateBinding Background}" Padding="{TemplateBinding Padding}">
                            <ContentPresenter />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="gd" Property="Background" Value="#1a9fff"/>
                            </Trigger>
                            <Trigger Property="IsSelected" Value="True">
                                <Setter TargetName="gd" Property="Background" Value="#2a475e"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- СТИЛЬ ДЛЯ САМОГО COMBOBOX (СОРТИРОВКИ) -->
        <Style TargetType="ComboBox">
            <Setter Property="Background" Value="#171a21"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="BorderBrush" Value="#2a475e"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Padding" Value="15,0,30,0"/>
            <Setter Property="Height" Value="40"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ComboBox">
                        <Grid>
                            <Border x:Name="border" Background="{TemplateBinding Background}" BorderBrush="{TemplateBinding BorderBrush}" BorderThickness="{TemplateBinding BorderThickness}" CornerRadius="4">
                                <ToggleButton x:Name="toggleButton" BorderThickness="0" Background="Transparent" Focusable="false" IsChecked="{Binding IsDropDownOpen, Mode=TwoWay, RelativeSource={RelativeSource TemplatedParent}}" ClickMode="Press">
                                    <ToggleButton.Template>
                                        <ControlTemplate TargetType="ToggleButton">
                                            <Border Background="Transparent">
                                                <Path Data="M 0 0 L 5 5 L 10 0 Z" Fill="#1a9fff" HorizontalAlignment="Right" VerticalAlignment="Center" Margin="0,0,15,0" Stretch="None"/>
                                            </Border>
                                        </ControlTemplate>
                                    </ToggleButton.Template>
                                </ToggleButton>
                            </Border>
                            <ContentPresenter Content="{TemplateBinding SelectionBoxItem}" ContentTemplate="{TemplateBinding SelectionBoxItemTemplate}" ContentTemplateSelector="{TemplateBinding ItemTemplateSelector}" Margin="{TemplateBinding Padding}" VerticalAlignment="Center" IsHitTestVisible="False"/>
                            <Popup x:Name="popup" AllowsTransparency="True" IsOpen="{TemplateBinding IsDropDownOpen}" Placement="Bottom" PopupAnimation="Slide">
                                <Border Background="#213245" BorderBrush="#1a9fff" BorderThickness="1" CornerRadius="4" MinWidth="{TemplateBinding ActualWidth}" MaxHeight="300" Margin="0,2,0,0">
                                    <ScrollViewer>
                                        <ItemsPresenter />
                                    </ScrollViewer>
                                </Border>
                            </Popup>
                        </Grid>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="border" Property="BorderBrush" Value="#1a9fff"/>
                            </Trigger>
                            <Trigger Property="IsDropDownOpen" Value="True">
                                <Setter TargetName="border" Property="BorderBrush" Value="#1a9fff"/>
                                <Setter TargetName="border" Property="Background" Value="#2a475e"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Стиль для списка жанров слева -->
        <Style x:Key="GenreListBoxItemStyle" TargetType="ListBoxItem">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="Foreground" Value="#c5c3c0"/>
            <Setter Property="Padding" Value="10,8"/>
            <Setter Property="Margin" Value="0,2"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ListBoxItem">
                        <Border Background="{TemplateBinding Background}" CornerRadius="4" Padding="{TemplateBinding Padding}">
                            <ContentPresenter />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Background" Value="#2a475e"/>
                                <Setter Property="Foreground" Value="White"/>
                            </Trigger>
                            <Trigger Property="IsSelected" Value="True">
                                <Setter Property="Background" Value="#1a9fff"/>
                                <Setter Property="Foreground" Value="White"/>
                                <Setter Property="FontWeight" Value="Bold"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Page.Resources>

    <Grid Background="#1b2838">
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="250"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <!-- ИСПРАВЛЕНИЕ: Удалено свойство LetterSpacing -->
        <Border Grid.Column="0" Background="#171a21" Padding="20">
            <StackPanel>
                <TextBlock Text="КАТЕГОРИИ" Foreground="#5c6d7e" FontWeight="Bold" FontSize="12" Margin="10,0,0,15"/>
                <ListBox x:Name="ListGenres" 
                         Background="Transparent" 
                         BorderThickness="0" 
                         SelectionChanged="ListGenres_SelectionChanged"
                         ItemContainerStyle="{StaticResource GenreListBoxItemStyle}">
                    <ListBox.ItemTemplate>
                        <DataTemplate>
                            <TextBlock Text="{Binding Name_Genre}" FontSize="16"/>
                        </DataTemplate>
                    </ListBox.ItemTemplate>
                </ListBox>
            </StackPanel>
        </Border>

        <Grid Grid.Column="1">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <Border Grid.Row="0" Background="#213245" Margin="20,20,20,10" CornerRadius="8" Padding="20">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>

                    <Image Grid.Column="0" Source="/Sourse/logo.png" Height="40" Margin="0,0,20,0" VerticalAlignment="Center"/>

                    <StackPanel Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Center">
                        <TextBlock Text="ПОИСК" Foreground="#1a9fff" FontWeight="Bold" FontSize="11" Margin="0,0,15,0" VerticalAlignment="Center"/>
                        <Border Background="#171a21" CornerRadius="4" Width="300" Height="40" BorderBrush="#1a9fff" BorderThickness="1">
                            <TextBox x:Name="TBoxSearch" Background="Transparent" BorderThickness="0" Foreground="White" 
                                     VerticalContentAlignment="Center" Padding="12,0" FontSize="16" CaretBrush="White"
                                     TextChanged="TBoxSearch_TextChanged"/>
                        </Border>
                    </StackPanel>

                    <StackPanel Grid.Column="2" Orientation="Horizontal" VerticalAlignment="Center">
                        <TextBlock Text="СОРТИРОВАТЬ" Foreground="#1a9fff" FontWeight="Bold" FontSize="11" Margin="0,0,15,0" VerticalAlignment="Center"/>
                        <ComboBox x:Name="ComboSort" Width="180" Height="40" SelectionChanged="ComboSort_SelectionChanged">
                            <ComboBoxItem Content="По умолчанию" IsSelected="True"/>
                            <ComboBoxItem Content="Цена (сначала дешевле)"/>
                            <ComboBoxItem Content="Цена (сначала дороже)"/>
                        </ComboBox>
                    </StackPanel>
                </Grid>
            </Border>

            <StackPanel x:Name="EmptyStatePanel" Grid.Row="1" VerticalAlignment="Center" HorizontalAlignment="Center" Visibility="Collapsed">
                <TextBlock Text="🎮" FontSize="80" Foreground="#2a475e" HorizontalAlignment="Center" Margin="0,0,0,10"/>
                <TextBlock Text="Ничего не найдено" Foreground="White" FontSize="24" FontWeight="Bold" HorizontalAlignment="Center" Margin="0,0,0,5"/>
                <TextBlock Text="Попробуйте изменить параметры поиска или выбрать другую категорию" Foreground="#5c6d7e" FontSize="16" HorizontalAlignment="Center"/>
            </StackPanel>

            <ScrollViewer Grid.Row="1" Margin="10,5,10,20">
                <ItemsControl x:Name="GameList">
                    <ItemsControl.ItemsPanel>
                        <ItemsPanelTemplate>
                            <WrapPanel HorizontalAlignment="Center"/>
                        </ItemsPanelTemplate>
                    </ItemsControl.ItemsPanel>

                    <ItemsControl.ItemTemplate>
                        <DataTemplate>
                            <Border x:Name="CardBorder" Width="260" Margin="10" Background="#2a475e" CornerRadius="12">
                                <StackPanel>
                                    <Border CornerRadius="12,12,0,0" ClipToBounds="True" Background="#171a21">
                                        <Image Height="260" Source="{Binding ImagePath}" Stretch="UniformToFill"/>
                                    </Border>
                                    <Border Padding="15">
                                        <StackPanel>
                                            <TextBlock Foreground="#a3db59" FontSize="11" FontWeight="Bold" Margin="0,0,0,6">
                                                <Run Text="{Binding Genre.Name_Genre}"/> • <Run Text="{Binding Developer.Name_Developer}"/>
                                            </TextBlock>
                                            <TextBlock Text="{Binding Title}" Foreground="White" FontSize="18" FontWeight="Bold" Margin="0,0,0,10" Height="45" TextWrapping="Wrap"/>
                                            <Grid Margin="0,0,0,15">
                                                <StackPanel Orientation="Horizontal">
                                                    <Border Background="#4c6b22" CornerRadius="2" Padding="6,2" Margin="0,0,8,0">
                                                        <TextBlock Text="{Binding RatingText}" Foreground="#beee11" FontWeight="Bold"/>
                                                    </Border>
                                                    <TextBlock Text="{Binding RatingText, Converter={StaticResource RatingToStarsConverter}}" Foreground="{Binding RatingText, Converter={StaticResource RatingToColorConverter}}" FontSize="16"/>
                                                </StackPanel>
                                                <TextBlock Text="{Binding PriceText}" HorizontalAlignment="Right" Foreground="White" FontSize="16" FontWeight="Bold"/>
                                            </Grid>
                                            <Button Content="КУПИТЬ" Click="Buy_Click" Background="#1a9fff" Foreground="White" FontWeight="Bold" BorderThickness="0" Height="35" Margin="0,0,0,8" Cursor="Hand"/>
                                            <UniformGrid Columns="2" Visibility="{Binding Source={x:Static Application.Current}, Path=MainWindow.Tag}">
                                                <Button Content="ПРАВКА" Click="Edit_Click" Background="#3d4450" Foreground="White" FontSize="10" Height="25" Margin="0,0,2,0"/>
                                                <Button Content="УДАЛИТЬ" Click="Delete_Click" Background="#a32b2b" Foreground="White" FontSize="10" Height="25" Margin="2,0,0,0"/>
                                            </UniformGrid>
                                        </StackPanel>
                                    </Border>
                                </StackPanel>
                            </Border>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>
            </ScrollViewer>
        </Grid>
    </Grid>
</Page>