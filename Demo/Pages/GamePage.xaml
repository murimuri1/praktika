<Page x:Class="Demo.Pages.GamePage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      Loaded="Page_Loaded"
      Title="Игры">

    <Grid Background="#1b2838">

        <Grid.RowDefinitions>
            <RowDefinition Height="60"/>
            <RowDefinition Height="60"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- ВЕРХ -->
        <DockPanel Grid.Row="0" Margin="10">
            <TextBlock Text="GAME STORE"
                       Foreground="White"
                       FontSize="24"
                       FontWeight="Bold"
                       DockPanel.Dock="Left"/>

            <Button Content="Библиотека"
                    Width="120"
                    DockPanel.Dock="Right"
                    Click="Library_Click"/>
        </DockPanel>

        <!-- ПОИСК + СОРТ -->
        <StackPanel Grid.Row="1" Orientation="Horizontal" HorizontalAlignment="Center">

            <!-- Блок Поиска -->
            <StackPanel Orientation="Horizontal" Margin="10,0,20,0">
                <TextBlock Text="Поиск по названию:" 
                           Foreground="White" 
                           VerticalAlignment="Center" 
                           Margin="0,0,10,0"
                           FontSize="14"/>
                <TextBox x:Name="TBoxSearch"
                         Width="250"
                         Height="30"
                         VerticalContentAlignment="Center"
                         TextChanged="TBoxSearch_TextChanged"/>
            </StackPanel>

            <!-- Блок Фильтрации -->
            <StackPanel Orientation="Horizontal" Margin="10,0,0,0">
                <TextBlock Text="Сортировка цены:" 
                           Foreground="White" 
                           VerticalAlignment="Center" 
                           Margin="0,0,10,0"
                           FontSize="14"/>
                <ComboBox x:Name="ComboSort"
                          Width="180"
                          Height="30"
                          VerticalContentAlignment="Center"
                          SelectionChanged="ComboSort_SelectionChanged">
                    <ComboBoxItem Content="По умолчанию" IsSelected="True"/>
                    <ComboBoxItem Content="Цена ↑"/>
                    <ComboBoxItem Content="Цена ↓"/>
                </ComboBox>
            </StackPanel>

        </StackPanel>

        <!-- ИГРЫ -->
        <ScrollViewer Grid.Row="2">
            <ItemsControl x:Name="GameList">

                <ItemsControl.ItemsPanel>
                    <ItemsPanelTemplate>
                        <WrapPanel HorizontalAlignment="Center"/>
                    </ItemsPanelTemplate>
                </ItemsControl.ItemsPanel>

                <ItemsControl.ItemTemplate>
                    <DataTemplate>

                        <!-- Немного увеличим ширину карточки до 240, чтобы влезло описание -->
                        <Border Width="240"
                                Margin="15"
                                Background="#2a475e"
                                CornerRadius="10">

                            <StackPanel>

                                <!-- Картинка -->
                                <Image Height="120"
                                       Source="{Binding ImagePath}"
                                       Stretch="UniformToFill"/>

                                <!-- Название -->
                                <TextBlock Text="{Binding Title}"
                                           Foreground="White"
                                           FontWeight="Bold"
                                           FontSize="16"
                                           Margin="10,10,10,2"
                                           TextWrapping="Wrap"/>

                                <!-- Жанр и Разработчик -->
                                <TextBlock Foreground="#a0a0a0" 
                                           FontSize="12" 
                                           Margin="10,0,10,5">
                                    <Run Text="{Binding Genre.Name_Genre}"/>
                                    <Run Text=" • "/>
                                    <Run Text="{Binding Developer.Name_Developer}"/>
                                </TextBlock>

                                <!-- Описание -->
                                <TextBlock Text="{Binding Description}"
                                           Foreground="#cccccc"
                                           FontSize="12"
                                           Margin="10,0,10,10"
                                           TextWrapping="Wrap"
                                           TextTrimming="CharacterEllipsis"
                                           Height="50"/>

                                <!-- Рейтинг -->
                                <StackPanel Orientation="Horizontal" Margin="10,0,10,5" VerticalAlignment="Center">
                                    <Border Background="#45a034" CornerRadius="4" Padding="6,2">
                                        <TextBlock Text="{Binding RatingText}" 
                                                   Foreground="White" 
                                                   FontWeight="Bold"
                                                   FontSize="14"/>
                                    </Border>
                                    <TextBlock Text="★★★★★" 
                                               Foreground="#ffc83d" 
                                               FontSize="16" 
                                               Margin="5,0,0,0" 
                                               VerticalAlignment="Center"/>
                                </StackPanel>

                                <!-- Цена -->
                                <TextBlock Text="{Binding PriceText}"
                                           Foreground="#a3db59"
                                           FontWeight="Bold"
                                           FontSize="14"
                                           Margin="10,0,10,10"/>

                                <!-- Кнопки -->
                                <StackPanel Orientation="Vertical" Margin="10,0,10,15">

                                    <!-- Кнопка Оплатить: Вернули базовый стиль через BasedOn -->
                                    <Button Content="Оплатить"
                                            MinHeight="30"
                                            Click="Buy_Click"
                                            Margin="0,0,0,5"
                                            Padding="0,5">
                                        <Button.Style>
                                            <Style TargetType="Button" BasedOn="{StaticResource {x:Type Button}}">
                                                <Setter Property="Visibility" Value="Visible"/>
                                                <Style.Triggers>
                                                    <DataTrigger Binding="{Binding Source={x:Static Application.Current}, Path=MainWindow.Tag}" Value="Visible">
                                                        <Setter Property="Visibility" Value="Collapsed"/>
                                                    </DataTrigger>
                                                </Style.Triggers>
                                            </Style>
                                        </Button.Style>
                                    </Button>

                                    <!-- Кнопка Редактировать: Видна только для Admin -->
                                    <Button Content="Редактировать"
                                            MinHeight="30"
                                            Click="Edit_Click"
                                            Margin="0,0,0,5"
                                            Padding="0,5"
                                            Visibility="{Binding Source={x:Static Application.Current}, Path=MainWindow.Tag}"/>

                                    <!-- Кнопка Удалить: Видна только для Admin -->
                                    <Button Content="Удалить"
                                            MinHeight="30"
                                            Click="Delete_Click"
                                            Padding="0,5"
                                            Visibility="{Binding Source={x:Static Application.Current}, Path=MainWindow.Tag}"/>

                                </StackPanel>

                            </StackPanel>
                        </Border>

                    </DataTemplate>
                </ItemsControl.ItemTemplate>

            </ItemsControl>
        </ScrollViewer>

    </Grid>
</Page>