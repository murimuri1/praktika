<Page x:Class="Demo.Pages.PayPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      Title="Оплата"
      FontFamily="Segoe UI">

    <Grid Background="#1b2838">
        <!-- Центрированная карточка оплаты с прокруткой -->
        <ScrollViewer VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled">
            <Border Width="450" 
                    VerticalAlignment="Center" 
                    HorizontalAlignment="Center" 
                    Background="#2a475e" 
                    CornerRadius="12"
                    Margin="0,50">
                <Border.Effect>
                    <DropShadowEffect BlurRadius="40" ShadowDepth="0" Opacity="0.6"/>
                </Border.Effect>

                <StackPanel>
                    <!-- Фото игры -->
                    <Border CornerRadius="12,12,0,0" Height="450" ClipToBounds="True" Background="#171a21">
                        <Image x:Name="ImgGame" Stretch="UniformToFill" Source="/Resurs/picture.png"/>
                    </Border>

                    <!-- Форма оплаты -->
                    <Border Padding="35">
                        <StackPanel>
                            <TextBlock x:Name="GameName"
                                       Text="Название игры"
                                       Foreground="White"
                                       FontSize="26"
                                       FontWeight="Bold"
                                       Margin="0,0,0,25"
                                       TextAlignment="Center"/>

                            <Border Height="1" Background="#1a9fff" Opacity="0.2" Margin="0,0,0,30"/>

                            <TextBlock Text="НОМЕР БАНКОВСКОЙ КАРТЫ"
                                       Foreground="#1a9fff"
                                       FontSize="11"
                                       FontWeight="Bold"
                                       Margin="0,0,0,8"/>
                            <Border Background="#171a21" CornerRadius="4" Margin="0,0,0,20" BorderBrush="#2a475e" BorderThickness="1">
                                <TextBox x:Name="CardNumber"
                                         Height="45"
                                         Background="Transparent"
                                         BorderThickness="0"
                                         Foreground="White"
                                         FontSize="18"
                                         VerticalContentAlignment="Center"
                                         Padding="15,0"
                                         MaxLength="16"
                                         PreviewTextInput="NumericOnly_PreviewTextInput"/>
                            </Border>

                            <!-- Срок действия и CVV: Строгая двумерная сетка -->
                            <Grid Margin="0,0,0,35">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="20"/>
                                    <!-- Отступ -->
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="Auto"/>
                                </Grid.RowDefinitions>

                                <!-- Заголовки полей -->
                                <TextBlock Grid.Row="0" Grid.Column="0" Text="СРОК ДЕЙСТВИЯ" Foreground="#1a9fff" FontSize="11" FontWeight="Bold" Margin="0,0,0,8"/>
                                <TextBlock Grid.Row="0" Grid.Column="2" Text="CVV / CVC КОД" Foreground="#1a9fff" FontSize="11" FontWeight="Bold" Margin="0,0,0,8"/>

                                <!-- Поле: Срок действия -->
                                <Border Grid.Row="1" Grid.Column="0" Background="#171a21" CornerRadius="4" BorderBrush="#2a475e" BorderThickness="1" HorizontalAlignment="Stretch">
                                    <TextBox x:Name="ExpiryDate"
                                             Height="45"
                                             Background="Transparent"
                                             BorderThickness="0"
                                             Foreground="White"
                                             FontSize="18"
                                             VerticalContentAlignment="Center"
                                             HorizontalContentAlignment="Center"
                                             Padding="0"
                                             MaxLength="5"
                                             TextChanged="ExpiryDate_TextChanged"
                                             PreviewTextInput="NumericOnly_PreviewTextInput"/>
                                </Border>

                                <!-- Поле: CVV -->
                                <Border Grid.Row="1" Grid.Column="2" Background="#171a21" CornerRadius="4" BorderBrush="#2a475e" BorderThickness="1" HorizontalAlignment="Stretch">
                                    <PasswordBox x:Name="CVV"
                                                 Height="45"
                                                 Background="Transparent"
                                                 BorderThickness="0"
                                                 Foreground="White"
                                                 FontSize="18"
                                                 VerticalContentAlignment="Center"
                                                 HorizontalContentAlignment="Center"
                                                 Padding="0"
                                                 MaxLength="3"/>
                                </Border>
                            </Grid>

                            <!-- Кнопка оплаты -->
                            <Button Content="ПОДТВЕРДИТЬ И ОПЛАТИТЬ"
                                    Height="50"
                                    Cursor="Hand"
                                    Click="Pay_Click">
                                <Button.Template>
                                    <ControlTemplate TargetType="Button">
                                        <Border x:Name="btn" Background="#1a9fff" CornerRadius="6">
                                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center">
                                                <ContentPresenter.Resources>
                                                    <Style TargetType="TextBlock">
                                                        <Setter Property="FontWeight" Value="Bold"/>
                                                        <Setter Property="Foreground" Value="White"/>
                                                        <Setter Property="FontSize" Value="14"/>
                                                    </Style>
                                                </ContentPresenter.Resources>
                                            </ContentPresenter>
                                        </Border>
                                        <ControlTemplate.Triggers>
                                            <Trigger Property="IsMouseOver" Value="True">
                                                <Setter TargetName="btn" Property="Background" Value="#31b0ff"/>
                                            </Trigger>
                                            <Trigger Property="IsPressed" Value="True">
                                                <Setter TargetName="btn" Property="Background" Value="#1588d4"/>
                                            </Trigger>
                                        </ControlTemplate.Triggers>
                                    </ControlTemplate>
                                </Button.Template>
                            </Button>

                            <!-- Кнопка Отмена -->
                            <Button Click="Cancel_Click" Margin="0,25,0,0" HorizontalAlignment="Center" Cursor="Hand">
                                <Button.Template>
                                    <ControlTemplate TargetType="Button">
                                        <TextBlock x:Name="txt" 
                                                   Text="ОТМЕНИТЬ ОПЕРАЦИЮ" 
                                                   Foreground="#5c6d7e" 
                                                   FontSize="12" 
                                                   FontWeight="SemiBold"
                                                   TextDecorations="Underline"/>
                                        <ControlTemplate.Triggers>
                                            <Trigger Property="IsMouseOver" Value="True">
                                                <Setter TargetName="txt" Property="Foreground" Value="White"/>
                                            </Trigger>
                                        </ControlTemplate.Triggers>
                                    </ControlTemplate>
                                </Button.Template>
                            </Button>
                        </StackPanel>
                    </Border>
                </StackPanel>
            </Border>
        </ScrollViewer>
    </Grid>
</Page>