<Page x:Class="Demo.Pages.LibraryPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      Title="БИБЛИОТЕКА"
      Loaded="Page_Loaded"
      FontFamily="Segoe UI">

    <Grid Background="#1b2838">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- ВЕРХНЯЯ ПАНЕЛЬ -->
        <Border Grid.Row="0" Background="#213245" Margin="20,20,20,10" CornerRadius="8" Padding="15">
            <StackPanel Orientation="Horizontal">
                <TextBlock Text="ВАША КОЛЛЕКЦИЯ" Foreground="#1a9fff" FontWeight="Bold" FontSize="12" VerticalAlignment="Center" Margin="0,0,20,0"/>
                <TextBlock x:Name="TxtCount" Text="0 игр" Foreground="#5c6d7e" FontSize="12" VerticalAlignment="Center"/>
            </StackPanel>
        </Border>

        <!-- СОСТОЯНИЕ "ПУСТО" (ЕСЛИ ИГР НЕТ) -->
        <StackPanel x:Name="EmptyStatePanel" Grid.Row="1" VerticalAlignment="Center" HorizontalAlignment="Center" Visibility="Collapsed">
            <TextBlock Text="📦" FontSize="100" Foreground="#2a475e" HorizontalAlignment="Center" Margin="0,0,0,10"/>
            <TextBlock Text="Ваша библиотека пуста" Foreground="White" FontSize="28" FontWeight="Bold" HorizontalAlignment="Center" Margin="0,0,0,10"/>
            <TextBlock Text="Время отправиться в магазин и найти что-то интересное!" Foreground="#5c6d7e" FontSize="16" HorizontalAlignment="Center" Margin="0,0,0,25"/>
            <Button Content="ПЕРЕЙТИ В МАГАЗИН" Click="GoToStore_Click" Width="220" Height="45" Background="#1a9fff" Foreground="White" FontWeight="Bold" Cursor="Hand">
                <Button.Template>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="btnBorder" Background="{TemplateBinding Background}" CornerRadius="4">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="btnBorder" Property="Background" Value="#31b0ff"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Button.Template>
            </Button>
        </StackPanel>

        <!-- СПИСОК ИГР -->
        <ScrollViewer x:Name="LibraryScrollViewer" Grid.Row="1" Margin="20,5,20,20" VerticalScrollBarVisibility="Auto">
            <ItemsControl x:Name="LibraryList">
                <ItemsControl.ItemsPanel>
                    <ItemsPanelTemplate>
                        <WrapPanel HorizontalAlignment="Center"/>
                    </ItemsPanelTemplate>
                </ItemsControl.ItemsPanel>
                <ItemsControl.ItemTemplate>
                    <DataTemplate>
                        <Border Width="260" Margin="10" Background="#2a475e" CornerRadius="12">
                            <StackPanel>
                                <Border CornerRadius="12,12,0,0" ClipToBounds="True" Background="#171a21">
                                    <Image Height="260" Source="{Binding Game.ImagePath}" Stretch="UniformToFill"/>
                                </Border>
                                <Border Padding="15">
                                    <StackPanel>
                                        <TextBlock Foreground="#a3db59" FontSize="11" FontWeight="Bold" Margin="0,0,0,6">
                                            <Run Text="{Binding Game.Genre.Name_Genre}"/> • <Run Text="{Binding Game.Developer.Name_Developer}"/>
                                        </TextBlock>
                                        <TextBlock Text="{Binding Game.Title}" Foreground="White" FontSize="18" FontWeight="Bold" Margin="0,0,0,10" Height="45" TextWrapping="Wrap"/>

                                        <!-- Кнопки управления с DataTriggers -->
                                        <Grid Height="35">
                                            <!-- Кнопка УСТАНОВИТЬ -->
                                            <Button x:Name="BtnInstall" Content="УСТАНОВИТЬ" Click="Install_Click" Background="#1a9fff" Foreground="White" FontWeight="Bold" Cursor="Hand">
                                                <Button.Template>
                                                    <ControlTemplate TargetType="Button">
                                                        <Border x:Name="brd" Background="{TemplateBinding Background}" CornerRadius="4">
                                                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                                        </Border>
                                                        <ControlTemplate.Triggers>
                                                            <Trigger Property="IsMouseOver" Value="True">
                                                                <Setter TargetName="brd" Property="Background" Value="#31b0ff"/>
                                                            </Trigger>
                                                        </ControlTemplate.Triggers>
                                                    </ControlTemplate>
                                                </Button.Template>
                                            </Button>

                                            <!-- Кнопки ИГРАТЬ и УДАЛИТЬ -->
                                            <UniformGrid x:Name="GridInstalled" Columns="2" Visibility="Collapsed">
                                                <Button Content="ИГРАТЬ" Click="Play_Click" Background="#a3db59" Foreground="#171a21" FontWeight="Bold" Margin="0,0,2,0" Cursor="Hand">
                                                    <Button.Template>
                                                        <ControlTemplate TargetType="Button">
                                                            <Border x:Name="brd" Background="{TemplateBinding Background}" CornerRadius="4">
                                                                <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                                            </Border>
                                                            <ControlTemplate.Triggers>
                                                                <Trigger Property="IsMouseOver" Value="True">
                                                                    <Setter TargetName="brd" Property="Background" Value="#beee11"/>
                                                                </Trigger>
                                                            </ControlTemplate.Triggers>
                                                        </ControlTemplate>
                                                    </Button.Template>
                                                </Button>
                                                <Button Content="🗑" Click="Delete_Click" Background="#3d4450" Foreground="#c5c3c0" FontSize="16" Margin="2,0,0,0" Cursor="Hand">
                                                    <Button.Template>
                                                        <ControlTemplate TargetType="Button">
                                                            <Border x:Name="brd" Background="{TemplateBinding Background}" CornerRadius="4">
                                                                <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                                            </Border>
                                                            <ControlTemplate.Triggers>
                                                                <Trigger Property="IsMouseOver" Value="True">
                                                                    <Setter TargetName="brd" Property="Background" Value="#a32b2b"/>
                                                                    <Setter Property="Foreground" Value="White"/>
                                                                </Trigger>
                                                            </ControlTemplate.Triggers>
                                                        </ControlTemplate>
                                                    </Button.Template>
                                                </Button>
                                            </UniformGrid>
                                        </Grid>
                                    </StackPanel>
                                </Border>
                            </StackPanel>
                        </Border>

                        <!-- Переключатель видимости кнопок на основе IsInstalled -->
                        <DataTemplate.Triggers>
                            <DataTrigger Binding="{Binding IsInstalled}" Value="True">
                                <Setter TargetName="BtnInstall" Property="Visibility" Value="Collapsed"/>
                                <Setter TargetName="GridInstalled" Property="Visibility" Value="Visible"/>
                            </DataTrigger>
                        </DataTemplate.Triggers>
                    </DataTemplate>
                </ItemsControl.ItemTemplate>
            </ItemsControl>
        </ScrollViewer>
    </Grid>
</Page>